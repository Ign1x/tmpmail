# =========================
# 必填
# =========================
# 用仓库自带 `docker compose up -d --build` 部署时，至少要填写以下两项。

# 默认管理用户 `admin` 的密码。首次启动时会用它引导后台管理员；至少 10 位。
TMPMAIL_ADMIN_PASSWORD=

# 公网稳定收件主机名。内置 Inbucket 在容器内网运行后，这一项应显式指向真正对外提供 MX 的主机名。
# 这个主机名必须能在公网直接接受 25/TCP SMTP 连接，且不能挂 Cloudflare 代理。
TMPMAIL_MAIL_EXCHANGE_HOST=

# =========================
# 选填 / 条件启用
# =========================
# 以下配置都有默认值，或者只在对应功能开启时才需要填写。

# -------------------------
# 基础监听与对外访问
# -------------------------
# API 容器内部监听地址。容器部署一般保持 0.0.0.0。
TMPMAIL_HOST=0.0.0.0
# API 对外端口。宿主机最终映射到哪个端口，由 compose 里的端口映射决定。
TMPMAIL_PORT=8080
# 前端对外端口。
TMPMAIL_FRONTEND_PORT=3000
# API 在宿主机上的绑定 IP。生产建议 127.0.0.1，只让反向代理或前端访问。
TMPMAIL_API_BIND_IP=127.0.0.1
# 前端在宿主机上的绑定 IP。对外开放通常保持 0.0.0.0。
TMPMAIL_FRONTEND_BIND_IP=0.0.0.0
# 容器运行用户。Linux 下建议改成宿主机当前用户的 UID/GID，避免 ./data 挂载写权限不匹配。
TMPMAIL_CONTAINER_UID=1000
TMPMAIL_CONTAINER_GID=1000
# 可选。填宿主机真实 IP 后，脚本会打印稳定可点击的访问地址。
TMPMAIL_PUBLIC_HOST=
# 前端代理后端 API 地址。容器内部署通常保持 http://api:8080；宿主机直连调试可改成 http://127.0.0.1:8080。
TMPMAIL_SERVER_API_BASE_URL=http://api:8080

# -------------------------
# 前端展示与本地测试
# -------------------------
# 管理台入口路径，默认是 /admin。
TMPMAIL_ADMIN_ENTRY_PATH=/admin
# 前端品牌名，留空则使用默认值。
NEXT_PUBLIC_TMPMAIL_BRAND_NAME=TmpMail
# 前端默认展示域名；留空时页面示例会回退到 mail.example.com。
NEXT_PUBLIC_TMPMAIL_DEFAULT_DOMAIN=
# 前端品牌域名展示，留空则显示品牌名或已配置默认域名。
NEXT_PUBLIC_TMPMAIL_BRAND_DOMAIN=
# 可选。前端仓库地址，用于页面里的外链。
NEXT_PUBLIC_TMPMAIL_REPO_URL=

# -------------------------
# 安全与认证
# -------------------------
# JWT 密钥。留空时，compose 会在首次启动自动生成并持久化到 ./data/runtime-secrets/jwt_secret。
# 如需查看自动生成值，可执行：docker compose logs secrets-init
TMPMAIL_JWT_SECRET=
# 管理员密码模式：bootstrap 只在首次引导创建默认 admin；force 会强制覆盖现有 admin 密码；disabled 完全忽略。
# 默认部署建议保持 bootstrap。
TMPMAIL_ADMIN_PASSWORD_MODE=bootstrap
# compose 自带 PostgreSQL 容器的数据库密码。留空时，compose 会在首次启动自动生成并持久化到 ./data/runtime-secrets/postgres_password。
# 如果 ./data/postgres 已经存在而这个密码文件丢失，系统会拒绝自动再生，避免把数据库密码悄悄改坏。
TMPMAIL_POSTGRES_PASSWORD=
# 仅供显式本地开发调试使用。开启后才允许弱/占位 JWT secret 继续启动。
TMPMAIL_ALLOW_INSECURE_DEV_SECRETS=false
# 是否强制管理员敏感操作必须走 HTTPS。公网建议 true，本地调试可改 false。
TMPMAIL_ADMIN_REQUIRE_SECURE_TRANSPORT=true
# 是否信任反向代理注入的 `X-Forwarded-*` / `Forwarded` 头。
# - 如果前面有一层你自己控制、并且会覆盖这些头的 HTTPS 反向代理（Nginx / Caddy / Traefik / ingress 等），这里应设为 true。
# - 如果是直接暴露服务，或者前面的代理不会严格覆盖这些头，这里应设为 false。
# `./scripts/dev-up.sh` 会按你的部署方式交互询问并写入这一项；如果你直接运行 `docker compose up -d --build`，请在首次启动前先显式决定。
TMPMAIL_TRUST_PROXY_HEADERS=
# 管理员会话有效期，单位秒。
TMPMAIL_ADMIN_SESSION_TTL_SECONDS=43200
# 可选。忘记管理员密码时使用的恢复令牌。平时建议留空。
TMPMAIL_ADMIN_RECOVERY_TOKEN=

# -------------------------
# SMTP（邮箱 OTP 发信）
# -------------------------
# 可选。配置后系统才能发送邮箱 OTP 邮件。
TMPMAIL_SMTP_HOST=
# SMTP 端口。
TMPMAIL_SMTP_PORT=587
# 可选。SMTP 用户名。
TMPMAIL_SMTP_USERNAME=
# 可选。SMTP 密码。
TMPMAIL_SMTP_PASSWORD=
# 可选。发件邮箱地址。
TMPMAIL_SMTP_FROM_ADDRESS=
# 可选。发件显示名称。
TMPMAIL_SMTP_FROM_NAME=TmpMail
# 是否启用 STARTTLS。
TMPMAIL_SMTP_STARTTLS=true

# Linux Do OAuth Client Secret。数据库会单独持久化该密钥；如需启动时覆盖，可通过环境变量提供。
TMPMAIL_LINUX_DO_CLIENT_SECRET=

# -------------------------
# Docker 构建（Rust / Node 依赖下载）
# -------------------------
# Cargo registry 协议，默认 sparse。
TMPMAIL_CARGO_REGISTRY_PROTOCOL=sparse
# 可选。若部署环境访问 crates.io 很慢，可改成镜像源，例如：
# sparse+https://rsproxy.cn/index/
TMPMAIL_CARGO_MIRROR=
# Cargo 下载重试次数。
TMPMAIL_CARGO_NET_RETRY=10
# Cargo HTTP 超时，单位秒。
TMPMAIL_CARGO_HTTP_TIMEOUT=120
# 可选。前端依赖下载镜像；如果 `frontend` 镜像构建卡在 `npm ci`，可改成：
# https://registry.npmmirror.com
TMPMAIL_NPM_REGISTRY=
# 前端 npm 拉包超时，单位毫秒。
TMPMAIL_NPM_FETCH_TIMEOUT=300000

# -------------------------
# 邮箱与账号默认策略
# -------------------------
# 对所有用户开放的公共域名，多个用逗号分隔；留空表示必须先在管理后台添加并验证真实域名。
TMPMAIL_PUBLIC_DOMAINS=
# 普通登录 Token 有效期，单位秒。
TMPMAIL_TOKEN_TTL_SECONDS=86400
# 默认账号有效期，单位秒；86400 表示 24 小时。
TMPMAIL_DEFAULT_ACCOUNT_TTL_SECONDS=86400
# 普通 API 请求超时，单位秒。
TMPMAIL_HTTP_REQUEST_TIMEOUT_SECONDS=15
# 普通 API 最大并发数；超过会快速返回 503。
TMPMAIL_HTTP_CONCURRENCY_LIMIT=256
# SSE 实时连接总上限；超过后 /events 会快速返回 503，避免长连接耗尽资源。
TMPMAIL_SSE_CONNECTION_LIMIT=128
# 是否公开暴露 Prometheus /metrics；默认关闭，只有接入受控采集端时才建议打开。
TMPMAIL_PUBLIC_METRICS_ENABLED=false
# 后台任务等待共享后台存储调度闸门的最长时间，单位毫秒；超时就跳过当轮，避免后台任务扎堆。
TMPMAIL_BACKGROUND_STORE_LOCK_TIMEOUT_MILLISECONDS=250

# -------------------------
# 域名解析与验证
# -------------------------
# MX 优先级。
TMPMAIL_MAIL_EXCHANGE_PRIORITY=10
# 公网部署通常必填。建议填写稳定共享收件主机，例如 mail.your-domain.tld。
# 配置后，每个托管域名都会生成：
#   CNAME mail.<你的域名> -> 这里配置的主机
#   MX    <你的域名> -> 这里配置的主机
# `TMPMAIL_MAIL_EXCHANGE_HOST` 已在上方必填区定义；如果你故意留空，系统会回退为每个域名自己的 mail.<你的域名>。
# 可选。只有在你不使用稳定共享收件主机、而是让每个域名继续走自己的 mail.<domain> 时，才需要填写这里的公网 IP 或上游主机名。
TMPMAIL_MAIL_CNAME_TARGET=
# 域名验证使用的 TXT 前缀。留空时直接把 TXT 放在域名本身上，推荐与常见托管邮箱服务保持一致。
TMPMAIL_DOMAIN_TXT_PREFIX=
# 域名验证轮询间隔，单位秒。
TMPMAIL_DOMAIN_VERIFICATION_POLL_INTERVAL_SECONDS=60
# 清理任务执行间隔，单位秒。
TMPMAIL_CLEANUP_INTERVAL_SECONDS=300
# 待验证域名保留时长，单位秒。
TMPMAIL_PENDING_DOMAIN_RETENTION_SECONDS=86400

# -------------------------
# Inbucket 收件调优
# -------------------------
# 主 compose 默认会自动拉起内置 Inbucket，并把 API 直接连到容器内网地址；通常不需要改下面这些项。
# 单次请求超时，单位秒。
TMPMAIL_INBUCKET_REQUEST_TIMEOUT_SECONDS=15
# 遇到瞬时网络错误或 408/429/5xx 时的重试次数。
TMPMAIL_INBUCKET_REQUEST_RETRIES=2
# Inbucket 重试基础退避时间，单位毫秒。
TMPMAIL_INBUCKET_RETRY_BACKOFF_MILLISECONDS=250
# Inbucket 轮询间隔，单位秒。
TMPMAIL_INBUCKET_POLL_INTERVAL_SECONDS=15

# -------------------------
# 本地 smoke 测试
# -------------------------
# 可选。冒烟脚本默认测试账号。建议填一个已激活的真实域名地址。
TMPMAIL_SMOKE_ADDRESS=
# 可选。冒烟脚本默认测试密码。仅本地测试使用。
TMPMAIL_SMOKE_PASSWORD=1234567890

# -------------------------
# Compose 内置 PostgreSQL
# -------------------------
# compose 自带 PostgreSQL 默认会读取这些项。
TMPMAIL_POSTGRES_DB=tmpmail
TMPMAIL_POSTGRES_USER=tmpmail
TMPMAIL_POSTGRES_BIND_IP=127.0.0.1
TMPMAIL_POSTGRES_PORT=5432
# 可选。若不使用 compose 自带 postgres，或要让宿主机直跑的后端连接外部数据库，再显式提供完整连接串。
# 留空时，后端会自动使用：
# postgres://<TMPMAIL_POSTGRES_USER>:<自动 URL 编码后的持久化 TMPMAIL_POSTGRES_PASSWORD>@postgres:5432/<TMPMAIL_POSTGRES_DB>
TMPMAIL_DATABASE_URL=
