TMPMAIL_HOST=0.0.0.0
TMPMAIL_PORT=8080
TMPMAIL_FRONTEND_PORT=3000
TMPMAIL_ADMIN_ENTRY_PATH=/admin
TMPMAIL_JWT_SECRET=change-me-in-production
TMPMAIL_DATABASE_URL=
TMPMAIL_ADMIN_STATE_PATH=data/config/admin-state.json
TMPMAIL_STORE_STATE_PATH=data/storage/store-state.json
TMPMAIL_ADMIN_REQUIRE_SECURE_TRANSPORT=true
TMPMAIL_ADMIN_SESSION_TTL_SECONDS=43200
TMPMAIL_PUBLIC_DOMAINS=tmpmail.local,inbox.tmpmail.local
TMPMAIL_TOKEN_TTL_SECONDS=86400
TMPMAIL_DEFAULT_ACCOUNT_TTL_SECONDS=86400
# Optional. Leave empty to publish MX -> mail.<your-domain> automatically.
TMPMAIL_MAIL_EXCHANGE_PRIORITY=10
TMPMAIL_MAIL_EXCHANGE_HOST=
# Optional. Leave empty to derive A/AAAA/CNAME target from TMPMAIL_INBUCKET_BASE_URL.
TMPMAIL_MAIL_CNAME_TARGET=
TMPMAIL_DOMAIN_TXT_PREFIX=_tmpmail-verify
TMPMAIL_DOMAIN_VERIFICATION_POLL_INTERVAL_SECONDS=60
TMPMAIL_INGEST_MODE=remote-inbucket
TMPMAIL_INBUCKET_BASE_URL=http://your-inbucket-host:9000
TMPMAIL_INBUCKET_USERNAME=
TMPMAIL_INBUCKET_PASSWORD=
TMPMAIL_INBUCKET_POLL_INTERVAL_SECONDS=15
TMPMAIL_POSTGRES_DB=tmpmail
TMPMAIL_POSTGRES_USER=tmpmail
TMPMAIL_POSTGRES_PASSWORD=tmpmail
TMPMAIL_POSTGRES_PORT=5432
